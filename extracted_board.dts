			compatible = "snps,dw-apb-uart";
			status = "okay";
			reg = <0x5000000 0x400>;
			phandle = <0x6d>;
			reg-shift = <0x02>;
		};
	};

	leds {
		compatible = "gpio-leds";

		gpio_2 {
			function = "wifi_wake";
			default-state = "on";
			gpios = <0x32 0x06 0x0f 0x00>;
		};

		led-1 {
			function = "status";
			color = <0x02>;
			gpio = <0x32 0x07 0x05 0x00>;
			default-state = "on";
			status = "disabled";
		};

		gpio_1 {
			function = "wifi_power";
			default-state = "on";
			gpios = <0x32 0x05 0x06 0x00>;
		};
	};

	psci {
		method = "smc";
		compatible = "arm,psci-0.2";
	};

	gpio_keys {
		compatible = "gpio-keys";
		status = "disabled";

		button_power {
			label = "Power";
			linux,code = <0x74>;
			debounce-interval = <0x64>;
		};
	};

	i2c-gpio {
		#address-cells = <0x01>;
		#size-cells = <0x00>;
		compatible = "i2c-gpio";
		status = "disabled";
		i2c-gpio,delay-us = <0x03>;
		phandle = <0xa4>;
		gpios = <0x32 0x08 0x06 0x00 0x32 0x08 0x04 0x00>;

		bh1750@5c {
			compatible = "rohm,bh1750";
			status = "disabled";
			reg = <0x5c>;
			phandle = <0xa6>;
		};

		ns2009@48 {
			ti,y-plate-ohms = <0x294>;
			i2c,ignore-nak = <0x01>;
			ti,fuzzy = <0x10>;
			compatible = "ti,tsc2007";
			status = "disabled";
			ti,x-plate-ohms = <0x294>;
			reg = <0x48>;
			phandle = <0xa5>;
			ti,fuzzx = <0x20>;
			ti,rt-thr = <0xbb8>;
		};
	};

	timer {
		arm,no-tick-in-suspend;
		interrupts = <0x01 0x0d 0xf04 0x01 0x0e 0xf04 0x01 0x0b 0xf04 0x01 0x0a 0xf04>;
		compatible = "arm,armv8-timer";
	};

	opp-table-cpu {
		opp-shared;
		compatible = "operating-points-v2";
		phandle = <0x03>;

		opp-1200000000 {
			opp-microvolt = <0xea600>;
			opp-hz = <0x00 0x47868c00>;
			clock-latency-ns = <0x3b9b0>;
		};

		opp-480000000 {
			opp-microvolt = <0xc8320>;
			opp-hz = <0x00 0x1c9c3800>;
			clock-latency-ns = <0x3b9b0>;
		};

		opp-1008000000 {
			opp-microvolt = <0xdbba0>;
			opp-hz = <0x00 0x3c14dc00>;
			clock-latency-ns = <0x3b9b0>;
		};

		opp-1512000000 {
			opp-microvolt = <0x10c8e0>;
			opp-hz = <0x00 0x5a1f4a00>;
			clock-latency-ns = <0x3b9b0>;
		};

		opp-792000000 {
			opp-microvolt = <0xd1f60>;
			opp-hz = <0x00 0x2f34f600>;
			clock-latency-ns = <0x3b9b0>;
		};

		opp-600000000 {
			opp-microvolt = <0xc8320>;
			opp-hz = <0x00 0x23c34600>;
			clock-latency-ns = <0x3b9b0>;
		};
	};

	vcc33-wifi {
		regulator-max-microvolt = <0x325aa0>;
		regulator-always-on;
		regulator-min-microvolt = <0x325aa0>;
		regulator-name = "vcc33-wifi";
		compatible = "regulator-fixed";
		phandle = <0x1d>;
		vin-supply = <0x53>;
	};

	aliases {
		ethernet0 = "/soc/ethernet@5030000";
		spi1 = "/soc/spi@5011000";
		serial4 = "/soc/serial@5001000";
		serial0 = "/soc/serial@5000000";
