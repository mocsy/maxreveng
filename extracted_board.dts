		};

		pwm4@0300a000 {
			pinctrl-names = "default";
			pinctrl-0 = <0x18>;
			compatible = "allwinner,sunxi-pwm4";
			phandle = <0x13>;
		};

		ir@7040000 {
			pinctrl-names = "default";
			pinctrl-0 = <0x4a>;
			clock-names = "apb\0ir";
			resets = <0x49 0x05>;
			interrupts = <0x00 0x6a 0x04>;
			clocks = <0x49 0x09 0x49 0x0b>;
			compatible = "allwinner,sun50i-h616-ir\0allwinner,sun6i-a31-ir";
			status = "disabled";
			reg = <0x7040000 0x400>;
			phandle = <0x9a>;
		};

		ahub_codec@0x05097000 {
			clock-names = "apb\0audio-codec-1x\0audio-codec-4x\0audio-hub";
			resets = <0x02 0x25>;
			clocks = <0x02 0x5f 0x02 0x5b 0x02 0x5c 0x02 0x5e>;
			compatible = "allwinner,sunxi-ahub";
			status = "okay";
			reg = <0x5097000 0xadf>;
			phandle = <0x25>;
		};

		watchdog@30090a0 {
			interrupts = <0x00 0x32 0x04>;
			clocks = <0x0d>;
			compatible = "allwinner,sun50i-h616-wdt\0allwinner,sun6i-a31-wdt";
			status = "okay";
			reg = <0x30090a0 0x20>;
			phandle = <0x5e>;
		};

		usb@5100000 {
			phy-names = "usb";
			resets = <0x02 0x32>;
			interrupts = <0x00 0x19 0x04>;
			clocks = <0x02 0x70>;
			extcon = <0x38 0x00>;
			compatible = "allwinner,sun50i-h616-musb\0allwinner,sun8i-h3-musb";
			status = "okay";
			interrupt-names = "mc";
			phys = <0x38 0x00>;
			reg = <0x5100000 0x400>;
