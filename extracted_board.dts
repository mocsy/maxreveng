/dts-v1/;

/ {
	#address-cells = <0x02>;
	model = "BigTreeTech CB1";
	serial-number = "32c05000bf61e8cd";
	#size-cells = <0x02>;
	interrupt-parent = <0x01>;
	compatible = "allwinner,sun50i-h616";

	vcc5v {
		regulator-max-microvolt = <0x4c4b40>;
		regulator-always-on;
		regulator-min-microvolt = <0x4c4b40>;
		regulator-name = "vcc-5v";
		compatible = "regulator-fixed";
		phandle = <0x53>;
	};

	opp-table-1 {
		compatible = "operating-points-v2";
		phandle = <0x45>;

		opp-650000000 {
			opp-microvolt = <0xf1b30>;
			opp-hz = <0x00 0x26be3680>;
		};

		opp-432000000 {
			opp-microvolt = <0xf1b30>;
			opp-hz = <0x00 0x19bfcc00>;
		};

		opp-200000000 {
			opp-microvolt = <0xf1b30>;
			opp-hz = <0x00 0xbebc200>;
		};

		opp-528000000 {
			opp-microvolt = <0xf1b30>;
			opp-hz = <0x00 0x1f78a400>;
		};

		opp-312000000 {
			opp-microvolt = <0xf1b30>;
			opp-hz = <0x00 0x1298be00>;
		};
	};

	connector {
		type = [64 00];
		compatible = "hdmi-connector";

		port {

			endpoint {
				remote-endpoint = <0x52>;
				phandle = <0x3d>;
			};
		};
	};

	wifi-pwrseq {
		clock-names = "osc32k-out";
		clocks = <0x0e 0x01>;
		reset-gpios = <0x32 0x06 0x12 0x01>;
		compatible = "mmc-pwrseq-simple";
		post-power-on-delay-ms = <0xc8>;
		phandle = <0x1f>;
	};

	thermal-zones {

		cpu-thermal {
			polling-delay = <0x3e8>;
			polling-delay-passive = <0x1f4>;
			thermal-sensors = <0x4d 0x02>;

			trips {

				cpu_crit {
					temperature = <0x19a28>;
					hysteresis = <0x7d0>;
					type = "critical";
					phandle = <0xa2>;
				};

				cpu_very_hot {
					temperature = <0x15f90>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x51>;
				};

				cpu_hot_pre {
					temperature = <0x13880>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x4f>;
				};

				cpu_hot {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x50>;
				};

				cpu_warm {
					temperature = <0x124f8>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x4e>;
				};
			};

			cooling-maps {

				cpu_very_hot_limit_cpu {
					trip = <0x51>;
					cooling-device = <0x06 0x05 0xffffffff>;
				};

				cpu_warm_limit_cpu {
					trip = <0x4e>;
					cooling-device = <0x06 0xffffffff 0x02>;
				};

				cpu_hot_limit_cpu {
					trip = <0x50>;
					cooling-device = <0x06 0x03 0x04>;
				};

				cpu_hot_pre_limit_cpu {
					trip = <0x4f>;
					cooling-device = <0x06 0x02 0x03>;
				};
			};
		};

		ddr-thermal {
			polling-delay = <0x00>;
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x4d 0x03>;
		};

		ve-thermal {
			polling-delay = <0x00>;
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x4d 0x01>;
		};

		gpu-thermal {
			polling-delay = <0x00>;
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x4d 0x00>;
		};
	};

	usb1-vbus {
		regulator-max-microvolt = <0x4c4b40>;
		enable-active-high;
		regulator-min-microvolt = <0x4c4b40>;
		regulator-name = "usb1-vbus";
		compatible = "regulator-fixed";
		status = "okay";
		phandle = <0x39>;
		vin-supply = <0x53>;
	};

	soc {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		compatible = "simple-bus";
		ranges = <0x00 0x00 0x00 0x40000000>;

		phy@5100400 {
			usb1_vbus-supply = <0x39>;
			clock-names = "usb0_phy\0usb1_phy\0usb2_phy\0usb3_phy\0pmu2_clk";
			reg-names = "phy_ctrl\0pmu0\0pmu1\0pmu2\0pmu3";
			resets = <0x02 0x26 0x02 0x27 0x02 0x28 0x02 0x29>;
			clocks = <0x02 0x61 0x02 0x63 0x02 0x65 0x02 0x67 0x02 0x6e>;
			#phy-cells = <0x01>;
			compatible = "allwinner,sun50i-h616-usb-phy";
			status = "okay";
			reg = <0x5100400 0x24 0x5101800 0x14 0x5200800 0x14 0x5310800 0x14 0x5311800 0x14>;
			phandle = <0x38>;
			reset-names = "usb0_reset\0usb1_reset\0usb2_reset\0usb3_reset";
		};

		pwm0@0300a000 {
			compatible = "allwinner,sunxi-pwm0";
			phandle = <0x0f>;
		};

		syscon@3000000 {
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			compatible = "allwinner,sun50i-h616-system-control";
			ranges;
			reg = <0x3000000 0x30 0x3000038 0xfc8>;
			phandle = <0x35>;

			sram@1a00000 {
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				compatible = "mmio-sram";
				ranges = <0x00 0x1a00000 0x200000>;
				reg = <0x1a00000 0x200000>;
				phandle = <0x5b>;

				sram-section@0 {
					compatible = "allwinner,sun50i-h616-sram-c1";
					reg = <0x00 0x200000>;
					phandle = <0x43>;
				};
			};

			sram@100000 {
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				compatible = "mmio-sram";
				ranges = <0x00 0x100000 0x18000>;
				reg = <0x100000 0x18000>;
				phandle = <0x58>;

				scpi-sram@17c00 {
					compatible = "arm,scp-shmem";
					reg = <0x17c00 0x200>;
					phandle = <0x59>;
				};
			};

			sram@28000 {
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				compatible = "mmio-sram";
				ranges = <0x00 0x28000 0x30000>;
				reg = <0x28000 0x30000>;
				phandle = <0x5a>;

				sram-section@0 {
					compatible = "allwinner,sun50i-h616-sram-c\0allwinner,sun50i-a64-sram-c";
					reg = <0x00 0x1e000>;
					phandle = <0x0a>;
				};
			};
		};

		mmc@4022000 {
			mmc-ddr-3_3v;
			pinctrl-names = "default";
			#address-cells = <0x01>;
			pinctrl-0 = <0x20>;
			clock-names = "ahb\0mmc";
			cap-sd-highspeed;
			bus-width = <0x08>;
			non-removable;
			resets = <0x02 0x10>;
			cap-sdio-irq;
			interrupts = <0x00 0x25 0x04>;
			clocks = <0x02 0x41 0x02 0x3e>;
			#size-cells = <0x00>;
			vmmc-supply = <0x1b>;
			no-1-8-v;
			mmc-ddr-1_8v;
			compatible = "allwinner,sun50i-h616-emmc\0allwinner,sun50i-a100-emmc";
			status = "okay";
			reg = <0x4022000 0x1000>;
			phandle = <0x69>;
			max-frequency = <0x2625a00>;
			cap-mmc-highspeed;
			reset-names = "ahb";
		};

		ahub-i2s3@0x05097000 {
			pinctrl-names = "default";
			daudio_master = <0x04>;
			pinctrl-0 = <0x26>;
			clock-names = "apb\0audio-codec-1x\0audio-codec-4x\0audio-hub";
			signal_inversion = <0x01>;
			mclk_div = <0x04>;
			clocks = <0x02 0x5f 0x02 0x5b 0x02 0x5c 0x02 0x5e>;
			pinconfig = <0x01>;
			frametype = <0x00>;
			compatible = "allwinner,sunxi-ahub-daudio";
			audio_format = <0x01>;
			slot_width_select = <0x20>;
			status = "disabled";
			tdm_num = <0x03>;
			reg = <0x5097000 0xadf>;
			phandle = <0x6c>;
			tdm_config = <0x01>;
			pcm_lrck_period = <0x20>;
		};

		ethernet@5030000 {
			rx-delay = <0x1f>;
			gmac-power1;
			pinctrl-names = "default";
			phy-supply = <0x1b>;
			phy-mode = "rmii";
			phy-rst;
			tx-delay = <0x07>;
			pinctrl-0 = <0x36>;
			clock-names = "bus-emac1\0emac-25m";
			reg-names = "gmac1_reg\0ephy_reg";
			local-mac-address = [02 00 bf 61 e8 cd];
			resets = <0x02 0x1f>;
			interrupts = <0x00 0x0f 0x04>;
			clocks = <0x02 0x53 0x02 0x51>;
			gmac-power2;
			gmac-power0;
			compatible = "allwinner,sunxi-gmac";
			status = "okay";
			interrupt-names = "gmacirq";
			reg = <0x5030000 0x10000 0x3000034 0x04>;
			phandle = <0x81>;
			allwinner,tx-delay-ps = <0x2bc>;
			phy-handle = <0x37>;
			reset-names = "stmmaceth";
			allwinner,rx-delay-ps = <0xc1c>;

			mdio {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				compatible = "ethernet-phy-ieee802.3-c22";
				phandle = <0x82>;

				ethernet-phy@1 {
					compatible = "ethernet-phy-ieee802.3-c22";
					reg = <0x01>;
					phandle = <0x37>;
				};
			};
		};

		hdmi@6000000 {
			reg-io-width = <0x01>;
			phy-names = "phy";
			clock-names = "iahb\0isfr\0tmds\0cec\0hdcp\0hdcp-bus";
			hvcc-supply = <0x3b>;
			resets = <0x02 0x33 0x02 0x3a>;
			interrupts = <0x00 0x3f 0x04>;
			clocks = <0x02 0x75 0x02 0x73 0x02 0x72 0x02 0x74 0x02 0x7e 0x02 0x7f>;
			drive-strength = <0x0a>;
			#sound-dai-cells = <0x00>;
			compatible = "allwinner,sun50i-h616-dw-hdmi";
			status = "okay";
			phys = <0x3a>;
			reg = <0x6000000 0x10000>;
			phandle = <0x8c>;
			reset-names = "ctrl\0hdcp";

			ports {
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				port@0 {
					reg = <0x00>;
					phandle = <0x8d>;

					endpoint {
						remote-endpoint = <0x3c>;
						phandle = <0x42>;
					};
				};

				port@1 {
					reg = <0x01>;
					phandle = <0x8e>;

					endpoint {
						remote-endpoint = <0x3d>;
						phandle = <0x52>;
					};
				};
			};
		};

		clock@7010000 {
			#reset-cells = <0x01>;
			clock-names = "hosc\0losc\0iosc\0pll-periph";
			clocks = <0x0d 0x0e 0x00 0x0e 0x02 0x02 0x04>;
			#clock-cells = <0x01>;
			compatible = "allwinner,sun50i-h616-r-ccu";
			reg = <0x7010000 0x210>;
			phandle = <0x49>;
		};

		pinctrl@300b000 {
			clock-names = "apb\0hosc\0losc";
			gpio-controller;
			interrupts = <0x00 0x33 0x04 0x00 0x34 0x04 0x00 0x35 0x04 0x00 0x2b 0x04 0x00 0x36 0x04 0x00 0x37 0x04 0x00 0x38 0x04 0x00 0x39 0x04>;
			clocks = <0x02 0x1a 0x0d 0x0e 0x00>;
			compatible = "allwinner,sun50i-h616-pinctrl";
			#interrupt-cells = <0x03>;
			reg = <0x300b000 0x400>;
			phandle = <0x32>;
			#gpio-cells = <0x03>;
			interrupt-controller;

			pwm4-pin {
				function = "pwm4";
				pins = "PH1";
				phandle = <0x18>;
			};

			uart4-ph-pins {
				function = "uart4";
				pins = "PI13\0PI14";
				phandle = <0x28>;
			};

			spi1-cs-pin {
				function = "spi1";
				pins = "PH9";
				phandle = <0x61>;
			};

			i2c4-pins {
				function = "i2c4";
				pins = "PH6\0PH7";
				phandle = <0x2f>;
			};

			rmii-pins {
				function = "emac1";
				pins = "PA0\0PA1\0PA2\0PA3\0PA4\0PA5\0PA6\0PA7\0PA8\0PA9";
				drive-strength = <0x28>;
				phandle = <0x36>;
			};

			pwm1-pin {
				function = "pwm1";
				pins = "PH3";
				phandle = <0x15>;
			};

			pwm5-pin {
				function = "pwm5";
				pins = "PA12";
				phandle = <0x19>;
			};

			mmc2-pins {
				function = "mmc2";
				pins = "PC0\0PC1\0PC5\0PC6\0PC8\0PC9\0PC10\0PC11\0PC13\0PC14\0PC15\0PC16";
				drive-strength = <0x1e>;
				phandle = <0x20>;
				bias-pull-up;
			};

			twi3-pins {
				function = "twi3";
				pins = "PA10\0PA11";
				phandle = <0x2c>;
				bias-pull-up;
			};

			i2c3-pins {
				function = "i2c3";
				pins = "PH4\0PH5";
				phandle = <0x60>;
			};

			can0_pin_irq {
				function = "irq";
				pins = "PI3";
				phandle = <0x34>;
				bias-pull-up;
			};

			ir-rx-pin {
				function = "ir_rx";
				pins = "PH10";
				phandle = <0x4a>;
			};

			mmc1-pins {
				function = "mmc1";
				pins = "PG0\0PG1\0PG2\0PG3\0PG4\0PG5";
				drive-strength = <0x28>;
				phandle = <0x1c>;
				bias-pull-up;
			};

			i2c2-pins {
				function = "i2c2";
				pins = "PH2\0PH3";
				phandle = <0x2b>;
			};

			pwm2-pin {
				function = "pwm2";
				pins = "PH2";
				phandle = <0x16>;
			};

			uart1-rts-cts-pins {
				function = "uart1";
				pins = "PG8\0PG9";
				phandle = <0x63>;
			};

			rgmii-pins {
				function = "emac0";
				pins = "PI0\0PI1\0PI2\0PI3\0PI4\0PI5\0PI7\0PI8\0PI9\0PI10\0PI11\0PI12\0PI13\0PI14\0PI15\0PI16";
				drive-strength = <0x28>;
				phandle = <0x5f>;
			};

			mmc0-pins {
				function = "mmc0";
				pins = "PF0\0PF1\0PF2\0PF3\0PF4\0PF5";
				drive-strength = <0x28>;
				phandle = <0x1a>;
				bias-pull-up;
			};

			i2c1-pins {
				function = "i2c1";
				pins = "PH0\0PH1";
				phandle = <0x2a>;
			};

			uart5-ph-pins {
				function = "uart5";
				pins = "PH2\0PH3";
				phandle = <0x66>;
			};

			spi1-pins {
				function = "spi1";
				pins = "PH6\0PH7\0PH8";
				phandle = <0x31>;
			};

			i2s3-pins {
				function = "i2s3";
				pins = "PH5\0PH6\0PH7\0PH8\0PH9";
				phandle = <0x26>;
			};

			pwm3-pin {
				function = "pwm3";
				pins = "PH0";
				phandle = <0x17>;
			};

			i2c0-pins {
				function = "i2c0";
				pins = "PI5\0PI6";
				phandle = <0x29>;
				bias-pull-up;
			};

			uart0-ph-pins {
				function = "uart0";
				pins = "PH0\0PH1";
				phandle = <0x27>;
			};

			uart2-rts-cts-pins {
				function = "uart2";
				pins = "PH7\0PH8";
				phandle = <0x65>;
			};

			uart1-pins {
				function = "uart1";
				pins = "PG6\0PG7";
				phandle = <0x62>;
			};

			spi0-pins {
				function = "spi0";
				pins = "PC0\0PC2\0PC4";
				phandle = <0x30>;
			};

			uart2-ph-pins {
				function = "uart2";
				pins = "PH5\0PH6";
				phandle = <0x64>;
			};
		};

		pwm5@0300a000 {
			pinctrl-names = "default";
			clk_bypass_output = <0x01>;
			pinctrl-0 = <0x19>;
			compatible = "allwinner,sunxi-pwm5";
			phandle = <0x14>;
		};

		pwm@300a000 {
			clock-names = "mod\0bus";
			resets = <0x02 0x0a>;
			clocks = <0x0d 0x02 0x2f>;
			pwm-number = <0x06>;
			#pwm-cells = <0x03>;
			compatible = "allwinner,sun50i-h616-pwm";
			status = "okay";
			reg = <0x300a000 0x400>;
			phandle = <0x54>;
			pwm-base = <0x00>;
			sunxi-pwms = <0x0f 0x10 0x11 0x12 0x13 0x14>;
		};

		bus@1000000 {
			#address-cells = <0x01>;
			allwinner,sram = <0x0a 0x01>;
			#size-cells = <0x01>;
			compatible = "allwinner,sun50i-h616-de33\0allwinner,sun50i-a64-de2";
			ranges = <0x00 0x1000000 0x400000>;
			reg = <0x1000000 0x400000>;

			mixer@100000 {
				clock-names = "bus\0mod";
				resets = <0x0b 0x00>;
				clocks = <0x0b 0x00 0x0b 0x06>;
				compatible = "allwinner,sun50i-h616-de33-mixer-0";
				reg = <0x100000 0x100000 0x8100 0x40 0x280000 0x20000>;
				phandle = <0x05>;

				ports {
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					port@1 {
						reg = <0x01>;
						phandle = <0x57>;

						endpoint {
							remote-endpoint = <0x0c>;
							phandle = <0x3f>;
						};
					};
				};
			};

			clock@8000 {
				#reset-cells = <0x01>;
				clock-names = "mod\0bus";
				resets = <0x02 0x01>;
				clocks = <0x02 0x1d 0x02 0x1e>;
				#clock-cells = <0x01>;
				compatible = "allwinner,sun50i-h616-de33-clk";
				reg = <0x8000 0x100>;
				phandle = <0x0b>;
			};
		};

		cpudai2-controller@0x05097000 {
			id = <0x02>;
			dma-names = "rx\0tx";
			compatible = "allwinner,sunxi-ahub-cpudai";
			status = "okay";
			reg = <0x5097000 0xadf>;
			phandle = <0x24>;
			dmas = <0x21 0x05 0x21 0x05>;
		};

		gpu@0x01800000 {
			mali-supply = <0x44>;
			clock-names = "core\0bus";
			resets = <0x02 0x03>;
			interrupts = <0x00 0x5f 0x04 0x00 0x60 0x04 0x00 0x61 0x04>;
			clocks = <0x02 0x23 0x02 0x24>;
			interrupt-parent = <0x01>;
			compatible = "allwinner,sun50i-h616-mali\0arm,mali-bifrost";
			status = "okay";
			interrupt-names = "job\0mmu\0gpu";
			reg = <0x1800000 0x40000>;
			phandle = <0x94>;
			operating-points-v2 = <0x45>;
			#cooling-cells = <0x02>;
		};

		i2c@5002800 {
			pinctrl-names = "default";
			#address-cells = <0x01>;
			pinctrl-0 = <0x2b>;
			resets = <0x02 0x19>;
			interrupts = <0x00 0x08 0x04>;
			clocks = <0x02 0x4a>;
			#size-cells = <0x00>;
			compatible = "allwinner,sun50i-h616-i2c\0allwinner,sun6i-a31-i2c";
			status = "disabled";
			reg = <0x5002800 0x400>;
			phandle = <0x75>;
		};

		ahub-i2s1@0x05097000 {
			daudio_master = <0x04>;
			clock-names = "apb\0audio-codec-1x\0audio-codec-4x\0audio-hub";
			signal_inversion = <0x01>;
			mclk_div = <0x01>;
			clocks = <0x02 0x5f 0x02 0x5b 0x02 0x5c 0x02 0x5e>;
