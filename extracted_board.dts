	display-engine {
		allwinner,pipelines = <0x05>;
		compatible = "allwinner,sun50i-h616-display-engine";
		status = "okay";
		phandle = <0x55>;
	};

	chosen {
		linux,initrd-end = <0x00 0x49fff958>;
		bootargs = "root=UUID=6fff31a7-2c07-4302-b461-2b4fd73ec00c rootwait rootfstype=ext4 bootsplash.bootfile=bootsplash.armbian console=ttyS0,115200 console=tty1 consoleblank=0 loglevel=7 ubootpart= usb-storage.quirks=   cgroup_enable=memory swapaccount=1";
		linux,initrd-start = <0x00 0x4972f000>;
		stdout-path = "serial0:115200n8";
	};

	ws2812 {
		pinctrl-names = "default";
		rgb_value = <0x01 0x10000>;
		rgb_cnt = <0x02>;
		compatible = "rgb-ws2812";
		status = "okay";
		phandle = <0xa3>;

		ws2812_pin@0 {
			gpios = <0x32 0x08 0x0f 0x01>;
		};
	};

	ac200_clk {
		#clock-cells = <0x00>;
		clock-frequency = <0x1e8480>;
		compatible = "pwm-clock";
		status = "okay";
		phandle = <0x2d>;
		pwms = <0x54 0x05 0x1f4 0x01>;
	};

	vcc-wifi-io {
		regulator-max-microvolt = <0x1b7740>;
		regulator-always-on;
		regulator-min-microvolt = <0x1b7740>;
		regulator-name = "vcc-wifi-io";
		compatible = "regulator-fixed";
		phandle = <0x1e>;
		vin-supply = <0x1d>;
	};

	pmu {
		interrupt-affinity = <0x06 0x07 0x08 0x09>;
		interrupts = <0x00 0x8c 0x04 0x00 0x8d 0x04 0x00 0x8e 0x04 0x00 0x8f 0x04>;
		compatible = "arm,cortex-a53-pmu";
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@1 {
			clocks = <0x02 0x15>;
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x01>;
			enable-method = "psci";
			phandle = <0x07>;
			operating-points-v2 = <0x03>;
			clock-latency-ns = <0x3b9b0>;
			#cooling-cells = <0x02>;
		};

		cpu@2 {
			clocks = <0x02 0x15>;
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x02>;
			enable-method = "psci";
			phandle = <0x08>;
			operating-points-v2 = <0x03>;
			clock-latency-ns = <0x3b9b0>;
			#cooling-cells = <0x02>;
		};

		cpu@0 {
			cpu-supply = <0x04>;
			clocks = <0x02 0x15>;
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			status = "okay";
			reg = <0x00>;
			enable-method = "psci";
			phandle = <0x06>;
			operating-points-v2 = <0x03>;
			clock-latency-ns = <0x3b9b0>;
			#cooling-cells = <0x02>;
		};

		cpu@3 {
			clocks = <0x02 0x15>;
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x03>;
			enable-method = "psci";
			phandle = <0x09>;
			operating-points-v2 = <0x03>;
			clock-latency-ns = <0x3b9b0>;
			#cooling-cells = <0x02>;
		};
	};

