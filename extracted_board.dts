	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		secmon@40000000 {
			reg = <0x00 0x40000000 0x00 0x80000>;
			phandle = <0x56>;
			no-map;
		};
	};

	mcp2515_clock {
		#clock-cells = <0x00>;
		clock-frequency = <0xb71b00>;
		compatible = "fixed-clock";
		phandle = <0x33>;
	};

	osc24M_clk {
		clock-output-names = "osc24M";
		#clock-cells = <0x00>;
		clock-frequency = <0x16e3600>;
		compatible = "fixed-clock";
		phandle = <0x0d>;
	};

	memory {
		device_type = "memory";
		reg = <0x00 0x40000000 0x00 0x40000000>;
	};
};
