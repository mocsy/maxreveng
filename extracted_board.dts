			interrupts = <0x00 0x01 0x04>;
			clocks = <0x02 0x43>;
			compatible = "snps,dw-apb-uart";
			status = "disabled";
			reg = <0x5000400 0x400>;
			phandle = <0x6e>;
			reg-shift = <0x02>;
		};

		dma-controller@3002000 {
			clock-names = "bus\0mbus";
			resets = <0x02 0x06>;
			interrupts = <0x00 0x2a 0x04>;
			clocks = <0x02 0x2a 0x02 0x32>;
			dma-requests = <0x31>;
			compatible = "allwinner,sun50i-h616-dma";
			reg = <0x3002000 0x1000>;
			phandle = <0x21>;
			dma-channels = <0x10>;
			#dma-cells = <0x01>;
		};

		usb@5200000 {
			phy-names = "usb";
			resets = <0x02 0x2b 0x02 0x2f 0x02 0x28>;
			interrupts = <0x00 0x1c 0x04>;
			clocks = <0x02 0x69 0x02 0x6d 0x02 0x62 0x02 0x65>;
			compatible = "allwinner,sun50i-h616-ehci\0generic-ehci";
			status = "okay";
			phys = <0x38 0x01>;
			reg = <0x5200000 0x100>;
			phandle = <0x86>;
		};

		hdmi-audio@1 {
			sunxi,snddaudio-codec = "hdmi-audio-codec.4.auto";
			compatible = "allwinner,sunxi-hdmi-machine";
			status = "okay";
			phandle = <0x8f>;
			sunxi,cpudai-controller = <0x3e>;
		};

		ethernet@5020000 {
			syscon = <0x35>;
			clock-names = "stmmaceth";
			resets = <0x02 0x1e>;
			interrupts = <0x00 0x0e 0x04>;
			clocks = <0x02 0x52>;
			compatible = "allwinner,sun50i-h616-emac\0allwinner,sun50i-a64-emac";
			status = "disabled";
			interrupt-names = "macirq";
			reg = <0x5020000 0x10000>;
			phandle = <0x7f>;
			reset-names = "stmmaceth";

			mdio {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				compatible = "snps,dwmac-mdio";
				phandle = <0x80>;
			};
		};

		codec@05096000 {
			clock-names = "apb\0audio-codec-1x\0audio-codec-4x";
			resets = <0x02 0x24>;
			interrupts = <0x00 0x3a 0x04>;
			clocks = <0x02 0x5d 0x02 0x5b 0x02 0x5c>;
			dma-names = "tx";
			#sound-dai-cells = <0x00>;
			compatible = "allwinner,sun50i-h616-codec";
			status = "okay";
			reg = <0x5096000 0x31c>;
			phandle = <0x6a>;
			dmas = <0x21 0x06>;
			allwinner,audio-routing = "Line Out\0LINEOUT";
		};

		sound@0 {
			sunxi,cpudai-controller2 = <0x24>;
			sunxi,cpudai-controller0 = <0x22>;
			sunxi,audio-codec = <0x25>;
			compatible = "allwinner,sunxi-ahub-machine";
			sunxi,cpudai-controller1 = <0x23>;
			status = "okay";
			phandle = <0x6b>;
		};

		serial@5000c00 {
			reg-io-width = <0x04>;
			resets = <0x02 0x14>;
			interrupts = <0x00 0x03 0x04>;
			clocks = <0x02 0x45>;
			compatible = "snps,dw-apb-uart";
			status = "disabled";
			reg = <0x5000c00 0x400>;
			phandle = <0x70>;
			reg-shift = <0x02>;
		};

		spi@5010000 {
			pinctrl-names = "default";
			#address-cells = <0x01>;
			pinctrl-0 = <0x30>;
			clock-names = "ahb\0mod";
			resets = <0x02 0x1c>;
			interrupts = <0x00 0x0c 0x04>;
			clocks = <0x02 0x4f 0x02 0x4d>;
			#size-cells = <0x00>;
			dma-names = "rx\0tx";
			compatible = "allwinner,sun50i-h616-spi\0allwinner,sun8i-h3-spi";
			status = "disabled";
			reg = <0x5010000 0x1000>;
			phandle = <0x7b>;
			dmas = <0x21 0x16 0x21 0x16>;
		};

		pinctrl@7022000 {
			clock-names = "apb\0hosc\0losc";
			gpio-controller;
			interrupts = <0x00 0x2b 0x04>;
			clocks = <0x49 0x02 0x0d 0x0e 0x00>;
			compatible = "allwinner,sun50i-h616-r-pinctrl";
			#interrupt-cells = <0x03>;
			reg = <0x7022000 0x400>;
			phandle = <0x98>;
			#gpio-cells = <0x03>;
			interrupt-controller;

			r-rsb-pins {
				function = "s_rsb";
				pins = "PL0\0PL1";
				phandle = <0x4b>;
			};

			r-i2c-pins {
				function = "s_i2c";
				pins = "PL0\0PL1";
				phandle = <0x99>;
			};
		};

		cpudai1-controller@0x05097000 {
			id = <0x01>;
			dma-names = "rx\0tx";
			compatible = "allwinner,sunxi-ahub-cpudai";
			status = "okay";
			reg = <0x5097000 0xadf>;
			phandle = <0x23>;
			dmas = <0x21 0x04 0x21 0x04>;
		};

		usb@5310000 {
			phy-names = "usb";
			resets = <0x02 0x2c 0x02 0x30>;
			interrupts = <0x00 0x1e 0x04>;
			clocks = <0x02 0x6a 0x02 0x6e 0x02 0x64>;
